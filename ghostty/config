# Ghostty config
# Docs: https://ghostty.org/docs/config

# Shell
command = /usr/bin/zsh

# Font
font-family = ""
font-family = "JetBrains Mono"
font-family = "Noto Color Emoji"
font-size = 11.5
adjust-cell-height = 5%
font-feature = calt
font-feature = clig
font-feature = liga

# Window / appearance
theme = "Ayu"
background-image = /home/xigo/dotfiles/ghostty/goku.jpg
background-image-opacity = 0.02
background-image-position = center
background-image-fit = cover
background-image-repeat = false
background-opacity = 1

# Cursor warp/trail shader from https://github.com/sahaj-b/ghostty-cursor-shaders
# This is the repo's most customizable Neovide-like cursor trail.
custom-shader = /home/xigo/dotfiles/ghostty/shaders/cursor_warp.glsl
custom-shader-animation = true

window-padding-x = 10
window-padding-y = 8
window-width = 120
window-height = 34
# Hide Ghostty's GTK header/title bar and window controls.
window-decoration = none
gtk-titlebar = false
mouse-hide-while-typing = true
confirm-close-surface = false

# Tabs
# Hide the tab/header bar; tabs remain accessible via shortcuts.
window-show-tab-bar = never
gtk-tabs-location = hidden
gtk-wide-tabs = false

# Cursor / scrollback
cursor-style = block
cursor-style-blink = true
scrollback-limit = 10000000

# tmux-like prefix mode: press Ctrl+B, then one key.
# Use key sequences instead of a one-shot key table so pressing Shift to type % or " doesn't cancel the prefix.
keybind = ctrl+b>c=new_tab
keybind = ctrl+b>n=next_tab
keybind = ctrl+b>p=previous_tab
keybind = ctrl+b>%=new_split:right
keybind = ctrl+b>shift+digit_5=new_split:right
keybind = ctrl+b>shift+apostrophe=new_split:down
keybind = ctrl+b>h=goto_split:left
keybind = ctrl+b>j=goto_split:down
keybind = ctrl+b>k=goto_split:up
keybind = ctrl+b>l=goto_split:right
keybind = ctrl+b>arrow_left=goto_split:left
keybind = ctrl+b>arrow_down=goto_split:down
keybind = ctrl+b>arrow_up=goto_split:up
keybind = ctrl+b>arrow_right=goto_split:right
keybind = ctrl+b>x=close_surface
keybind = ctrl+b>z=toggle_split_zoom
keybind = ctrl+b>ctrl+b=text:\x02
